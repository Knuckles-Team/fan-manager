{
  "mcpServers": {
    "fan-manager": {
      "command": "uvx",
      "args": [
        "--from",
        "fan-manager",
        "fan-manager-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "TRANSPORT": "stdio",
        "TEMPERATURETOOL": "True",
        "FAN_CONTROLTOOL": "True",
        "IPMITOOL": "True"
      }
    }
  }
}
